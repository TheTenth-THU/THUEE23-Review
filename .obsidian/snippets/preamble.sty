%%%%%%%%%%%%%%%%%%%%%%%% 分式 %%%%%%%%%%%%%%%%%%%%%%%%
\renewcommand{\frac}[2]{\mathchoice{\genfrac{}{}{}{1}{\displaystyle #1}{\displaystyle #2}}{\genfrac{}{}{}{1}{\textstyle #1}{\textstyle #2}}{\genfrac{}{}{}{2}{\scriptstyle #1}{\scriptstyle #2}}{\genfrac{}{}{}{3}{\scriptscriptstyle #1}{\scriptscriptstyle #2}}}
\renewcommand{\dfrac}[2]{\genfrac{}{}{}{1}{\textstyle #1}{\textstyle #2}}
\renewcommand{\tfrac}[2]{\genfrac{}{}{}{2}{\scriptstyle #1}{\scriptstyle #2}}
\renewcommand{\binom}[2]{\genfrac(){0pt}{1}{\textstyle #1}{\textstyle #2}}

