{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "skills": {
    "paths": [".opencode/skills"]
  },
  "permission": {
    "edit": "allow",
    "bash": {
      "git *": "allow",
      "ls *": "allow",
      "dir *": "allow",
      "find *": "allow",
      "pwd": "allow",
      "echo *": "allow",
      "mkdir *": "allow",
      "mv *": "allow",
      "cp *": "allow",
      "cd *": "allow",
      "node *": "allow",
      "python *": "allow",
      "pip *": "allow",
      "npm *": "allow",
      "npx *": "allow",
      "pdflatex *": "allow",
      "xelatex *": "allow",
      "latexmk *": "allow",
      "which *": "allow",
      "where *": "allow",
      "type *": "allow",
      "*": "allow"
    },
    "external_directory": {
      "*": "allow"
    }
  }
}
